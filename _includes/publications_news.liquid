<div class="pubnews-grid">
  <div class="pubnews-col">
    <div class="pubnews-heading">Publications</div>

    <div class="pubnews-subheading">Papers</div>
    {% for item in site.data.publications.papers %}
      <div class="pub-entry">
        {% assign lines = item.text | split: "
" %}
        {% for line in lines %}
          {% assign stripped = line | strip %}
          {% unless stripped == "" %}
            <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endfor %}

    {% if site.data.publications.thesis %}
      <div class="pubnews-subheading">Thesis</div>
      {% for item in site.data.publications.thesis %}
        <div class="pub-entry">
          {% assign lines = item.text | split: "
" %}
          {% for line in lines %}
            {% assign stripped = line | strip %}
            {% unless stripped == "" %}
              <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
            {% endunless %}
          {% endfor %}
        </div>
      {% endfor %}
    {% endif %}

    <div class="pubnews-subheading">Extended Abstracts</div>
    {% for item in site.data.publications.extended_abstracts %}
      <div class="pub-entry">
        {% assign lines = item.text | split: "
" %}
        {% for line in lines %}
          {% assign stripped = line | strip %}
          {% unless stripped == "" %}
            <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>

  <div class="pubnews-col">
    <div class="pubnews-heading">News</div>

    {% for item in site.data.news.items %}
      <div class="news-entry">
        {% assign lines = item.text | split: "
" %}
        {% for line in lines %}
          {% assign stripped = line | strip %}
          {% unless stripped == "" %}
            <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>