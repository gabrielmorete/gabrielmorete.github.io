<div style="clear: both;"></div>
<hr style="border: 0; border-top: 1px solid #d9d9d9; margin: 1.75rem 0 2rem 0;">

<div class="pubnews-grid">
  <div class="pubnews-col">
    <div class="pubnews-heading">Papers</div>

    {% for item in site.data.publications.papers %}
      <div class="pub-entry">
        {% assign lines = item.text | split: "
" %}
        {% for line in lines %}
          {% assign stripped = line | strip %}
          {% unless stripped == "" %}
            <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endfor %}

    {% if site.data.publications.thesis %}
      <div class="pubnews-heading" style="margin-top: 2rem;">Thesis</div>

      {% for item in site.data.publications.thesis %}
        <div class="pub-entry">
          {% assign lines = item.text | split: "
" %}
          {% for line in lines %}
            {% assign stripped = line | strip %}
            {% unless stripped == "" %}
              <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
            {% endunless %}
          {% endfor %}
        </div>
      {% endfor %}
    {% endif %}

    <div class="pubnews-heading" style="margin-top: 2rem;">Extended Abstracts</div>

    {% for item in site.data.publications.extended_abstracts %}
      <div class="pub-entry">
        {% assign lines = item.text | split: "
" %}
        {% for line in lines %}
          {% assign stripped = line | strip %}
          {% unless stripped == "" %}
            <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>

  <div class="pubnews-col">
    <div class="pubnews-heading">News</div>

    {% for item in site.data.news.items %}
      <div class="news-entry">
        {% assign lines = item.text | split: "
" %}
        {% for line in lines %}
          {% assign stripped = line | strip %}
          {% unless stripped == "" %}
            <div>{{ stripped | markdownify | remove: '<p>' | remove: '</p>' }}</div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>